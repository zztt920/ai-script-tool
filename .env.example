# AI 剧本创作工具 — 环境变量配置模板
# 复制为 .env 并填入实际值

# ── OpenAI 兼容 API ──────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=deepseek-v4-flash

# ── 数据库 ────────────────────────────────────────
SCRIPT_DB_PATH=/app/data/script_tool.db

# ── 服务配置 ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_CHAPTER_SIZE_MB=10

# ── 部署配置 ──────────────────────────────────────
COMPOSE_PROJECT_NAME=script-tool
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
